library(sf)
library(dplyr)
library(ggplot2)
library(dbscan)
install.packages("dbscan")
library(sf)
library(dplyr)
library(ggplot2)
library(dbscan)
bees_proj <- bees_sf %>% st_transform(3857)
coords <- st_coordinates(bees_proj)
db <- dbscan(coords, eps = 500, minPts = 5)  # eps in meters here
bees_proj$cluster <- factor(db$cluster)
ggplot() +
geom_sf(data = st_transform(parks, 3857), fill = "grey95", color = "grey75", linewidth = 0.2) +
geom_sf(data = bees_proj, aes(color = cluster), size = 1, alpha = 0.7) +
theme_minimal()
db <- dbscan(coords, eps = 1000, minPts = 5)  # eps in meters here
bees_proj$cluster <- factor(db$cluster)
ggplot() +
geom_sf(data = st_transform(parks, 3857), fill = "grey95", color = "grey75", linewidth = 0.2) +
geom_sf(data = bees_proj, aes(color = cluster), size = 1, alpha = 0.7) +
theme_minimal()
