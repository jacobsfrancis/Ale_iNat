explore_Plot1 <- ggplot(
data = Apid_Summary_20_plot,
aes(
x = reorder(park_label, percentageHB),
y = percentageHB,
color = percentageHB
)
) +
geom_point(
aes(size = n_apidae),
alpha = 0.9
) +
geom_text(
aes(
y = 108,
label = n_apidae
),
color = "grey25",
size = 3.5,
hjust = 0.5
) +
annotate(
"text",
x = 1,
y = 108,
label = "No. Anthophila\nobservations",
hjust = 0.5,
vjust = -0.6,
size = 3.6,
fontface = "bold",
color = "grey20"
) +
coord_flip(clip = "off") +
scale_color_gradientn(
colors = hb_ramp,
name = "% honey bee"
) +
scale_y_continuous(
limits = c(0, 112),
breaks = seq(0, 100, 20),
labels = function(x) paste0(x, "%"),
expand = expansion(mult = c(0.01, 0.02))
) +
scale_size_continuous(
range = c(2.5, 9),
name = "Number of Anthophila\nobservations"
) +
theme_minimal(base_size = 13) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
axis.title.y = element_blank(),
legend.position = "right",
legend.title = element_text(size = 11),
legend.text = element_text(size = 10),
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11),
plot.margin = margin(10, 55, 10, 10)
) +
labs(
title = expression(italic("Apis") ~ " relative abundance by park"),
subtitle = "Parks with more than 5 Anthophila observations",
x = NULL,
y = "Honey bee observations"
)
