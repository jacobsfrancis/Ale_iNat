# spatial join: attach park attributes to each bee point ####
bees_by_park <- st_join(bees_sf, parks, join = st_within)
## make bee points in ST format ####
bees_sf <- bees %>%
filter(!is.na(decimalLongitude), !is.na(decimalLatitude)) %>%
st_as_sf(coords = c("decimalLongitude", "decimalLatitude"), crs = 4326)
source("~/Documents/ScienceProjects/2026/Ale_iNat/Analysis/Exploration.R", echo = TRUE)
View(bees_by_park)
View(bees_by_park)
#2.0 Remove obs not in parks####
bees_by_park %>% filter(!is.na(poly_id))
#2.0 Remove obs not in parks####
bees_in_parks <- bees_by_park %>% filter(!is.na(poly_id))
View(bees_in_parks)
bees_in_parks %>%
group_by(poly_id) %>%
summarise(
n_apidae = n(),
n_hb = sum(genus == "Apis", na.rm = TRUE),
percentageHB = 100 * n_hb / n_apidae
)
Apid_Summary <- bees_in_parks %>%
group_by(poly_id) %>%
summarise(
n_apidae = n(),
n_hb = sum(genus == "Apis", na.rm = TRUE),
percentageHB = 100 * n_hb / n_apidae
)
Apid_Summary_20 <-  Apid_Summary %>% filter(n_apidae>19)
Apid_Summary_20 <-  Apid_Summary %>% filter(n_apidae>14)
library(ggplot2)
source("~/Documents/ScienceProjects/2026/Ale_iNat/Analysis/Exploration.R", echo = TRUE)
